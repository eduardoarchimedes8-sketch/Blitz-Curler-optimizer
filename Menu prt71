local function addToggleRow(name, order)
    local row = Instance.new("TextButton")
    row.LayoutOrder = order
    row.Size = UDim2.new(1, 0, 0, 44)
    row.BackgroundColor3 = THEME.RowOff
    row.AutoButtonColor = false
    row.Text = ""
    row.Parent = ListHolder

    local rowCorner = Instance.new("UICorner")
    rowCorner.CornerRadius = UDim.new(0, 8)
    rowCorner.Parent = row

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, -20, 1, 0)
    label.Position = UDim2.new(0, 10, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = name .. ": OFF"
    label.Font = Enum.Font.GothamBold
    label.TextSize = 15
    label.TextColor3 = THEME.TextOff
    label.TextXAlignment = Enum.TextXAlignment.Center
    label.Parent = row

    local state = false
    local isOptimizer = (name == "BLITZ CURLER OPTIMIZER")
    local isShadowToggle = (name == "AIMBOT")
    local isPingToggle = (name == "CONTADOR DE PING")

    row.MouseButton1Click:Connect(function()
        state = not state
        if state then
            row.BackgroundColor3 = THEME.RowOn
            label.Text = name .. ": ON"
            label.TextColor3 = THEME.TextOn
        else
            row.BackgroundColor3 = THEME.RowOff
            label.Text = name .. ": OFF"
            label.TextColor3 = THEME.TextOff
        end

        -- Somente estes itens chamam função real de jogo.
        if isOptimizer then
            OPTIMIZE_ENABLED = state
            if OPTIMIZE_ENABLED then
                enableOptimization()
            else
                disableOptimization()
            end
        end

        if isShadowToggle then
            if state then
                lowShadows()
            else
                restoreShadows()
            end
        end

        if isPingToggle then
            if state then
                enablePingCounter()
            else
                disablePingCounter()
            end
        end
    end)
end

for i, itemName in ipairs(MENU_ITEMS) do
