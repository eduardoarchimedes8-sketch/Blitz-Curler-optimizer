----------------------------------------------------------------
-- LÓGICA REAL: OTIMIZAÇÃO GRÁFICA (item BLITZ CURLER OPTIMIZER)
----------------------------------------------------------------
-- Observação importante: Texturas e Decais são DELETADOS pela
-- otimização (Destroy()). Uma vez deletados, não existe forma
-- de "recriar" o objeto original — isso é uma limitação de
-- qualquer script que apague instâncias, não só deste.
-- Já Material, Reflectance, e Enabled (de partículas/trails)
-- são apenas alterados, então guardamos o valor original de
-- cada um para poder devolver de verdade ao desativar.

local OPTIMIZE_ENABLED = false
local descendantConn
local originalValues = {} -- [instancia] = {Material=..., Reflectance=..., Enabled=...}

local function optimize(obj)
    if obj:IsA("Texture") or obj:IsA("Decal") then
        obj:Destroy() -- irreversível: não há como restaurar depois

    elseif obj:IsA("BasePart") then
        if not originalValues[obj] then
            originalValues[obj] = { Material = obj.Material, Reflectance = obj.Reflectance }
        end
        obj.Material = Enum.Material.SmoothPlastic
        obj.Reflectance = 0

    elseif obj:IsA("ParticleEmitter") or obj:IsA("Trail") then
        if not originalValues[obj] then
            originalValues[obj] = { Enabled = obj.Enabled }
        end
        obj.Enabled = false
    end
end

local function restoreOne(obj, data)
    if not obj or not obj.Parent then return end
    if obj:IsA("BasePart") and data.Material then
        obj.Material = data.Material
        obj.Reflectance = data.Reflectance
    elseif (obj:IsA("ParticleEmitter") or obj:IsA("Trail")) and data.Enabled ~= nil then
        obj.Enabled = data.Enabled
    end
end

local function enableOptimization()
    for _, v in pairs(workspace:GetDescendants()) do
        optimize(v)
    end
    if not descendantConn then
        descendantConn = workspace.DescendantAdded:Connect(function(obj)
            if not OPTIMIZE_ENABLED then return end
            task.wait(0.1)
            optimize(obj)
        end)
    end
end

local function disableOptimization()
    if descendantConn then
        descendantConn:Disconnect()
        descendantConn = nil
    end

    -- Restaura Material/Reflectance/Enabled de tudo que foi alterado
    for obj, data in pairs(originalValues) do
        restoreOne(obj, data)
    end
    table.clear(originalValues)

    -- Texturas/Decais destruídos NÃO voltam (foram apagados de vez)
end

----------------------------------------------------------------
-- LÓGICA REAL: REDUZIR SOMBRAS (item "AIMBOT" — nome é só
-- brincadeira, a função só mexe na iluminação/sombras)
----------------------------------------------------------------

local Lighting = game:GetService("Lighting")

local SHADOWS_ENABLED_ORIGINAL
local GLOBAL_SHADOWS_ORIGINAL

local function lowShadows()
    -- Guarda os valores originais na primeira vez, para
    -- poder devolver depois
    if SHADOWS_ENABLED_ORIGINAL == nil then
        SHADOWS_ENABLED_ORIGINAL = Lighting.GlobalShadows
    end

    Lighting.GlobalShadows = false

    -- Reduz também a sombra "de contato" das partes, se existir
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") then
            v.CastShadow = false
        end
    end
end

local function restoreShadows()
    if SHADOWS_ENABLED_ORIGINAL ~= nil then
        Lighting.GlobalShadows = SHADOWS_ENABLED_ORIGINAL
    end

    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") then
            v.CastShadow = true
        end
    end
end

----------------------------------------------------------------
-- LÓGICA REAL: CONTADOR DE PING AO VIVO
----------------------------------------------------------------

local RunService = game:GetService("RunService")
local Stats = game:GetService("Stats")

local PingLabel
local pingConn

local function getPingMs()
    local ok, value = pcall(function()
        return Stats.Network.ServerStatsItem["Data Ping"]:GetValue()
    end)
    if ok and value then
        return math.floor(value)
    end
    return nil
end

local function createPingLabel()
    if PingLabel and PingLabel.Parent then return end

    PingLabel = Instance.new("TextLabel")
    PingLabel.Name = "PingCounter"
    PingLabel.Size = UDim2.new(0, 140, 0, 36)
    PingLabel.Position = UDim2.new(0, 20, 0, 20)
    PingLabel.BackgroundColor3 = THEME.Background
    PingLabel.BackgroundTransparency = 0.2
    PingLabel.Text = "PING: --ms"
    PingLabel.Font = Enum.Font.GothamBold
    PingLabel.TextSize = 16
    PingLabel.TextColor3 = THEME.AccentLight
    PingLabel.Parent = ScreenGui

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 8)
    corner.Parent = PingLabel
end

local function enablePingCounter()
    createPingLabel()
    PingLabel.Visible = true

    if not pingConn then
        pingConn = RunService.Heartbeat:Connect(function()
            local ms = getPingMs()
            if ms then
                PingLabel.Text = "PING: " .. ms .. "ms"
            end
        end)
    end
end

local function disablePingCounter()
    if pingConn then
        pingConn:Disconnect()
        pingConn = nil
    end
    if PingLabel then
        PingLabel.Visible = false
    end
end

